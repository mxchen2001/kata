# Nested function calls — @call inside @task resolves the function first,
# then inlines its output as reference material for higher determinism.

@fn implement(spec) {
  @model claude-sonnet-4-6
  @role :coder(Python)
  @task {
    Implement the following specification as a Python module.
    Only output the code, no explanation.

    ${spec}
  }
  @constraint Use type hints on all functions.
  @constraint No external dependencies — stdlib only.
  @output format: python, file: solution.py
}

@model claude-sonnet-4-6
@role :tester
@task {
  Write a mock wrapper and test suite for the following implementation:
  @call implement(A duration parser that converts human-readable strings like "2h30m" and "1d12h" and "45s" and "1w2d" into total seconds. Support w/d/h/m/s units. Raise ValueError on invalid input.)
}
@constraint Each test should have a descriptive name.
@constraint Group related tests in classes.
@output format: python, file: test_solution.py
