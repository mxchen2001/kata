{
  "name": "kata-lang",
  "displayName": "Kata 型",
  "description": "Syntax highlighting for the Kata LLM programming language",
  "version": "0.1.0",
  "publisher": "kata",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "kata",
        "aliases": ["Kata", "kata"],
        "extensions": [".kata"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "kata",
        "scopeName": "source.kata",
        "path": "./syntaxes/kata.tmLanguage.json"
      }
    ]
  }
}
